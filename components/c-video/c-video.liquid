{% liquid
  assign video_media = video
  assign thumbnail_image = thumbnail
  assign thumbnail_label = thumbnail_alt
  assign wrapper_class = class
  assign root_id = id
  assign should_loop = loop
  assign resolved_aspect_ratio = aspect_ratio

  if should_loop == nil
    assign should_loop = true
  endif

  if resolved_aspect_ratio == blank and video_media.aspect_ratio != blank
    assign resolved_aspect_ratio = video_media.aspect_ratio
  endif

  if resolved_aspect_ratio == blank
    assign resolved_aspect_ratio = '260 / 340'
  endif

  if thumbnail_image == blank and video_media.preview_image != blank
    assign thumbnail_image = video_media.preview_image
  endif

  if thumbnail_label == blank and thumbnail_image.alt != blank
    assign thumbnail_label = thumbnail_image.alt
  endif
%}

{% if video_media != blank %}
  <div
    {% if root_id != blank %}id="c-video-{{ root_id | handleize }}"{% endif %}
    data-nazare-use="snippets/c-video"
    style="--c-video-aspect-ratio: {{ resolved_aspect_ratio | escape }};"
    class="group relative aspect-[var(--c-video-aspect-ratio)] overflow-hidden bg-foreground text-background shadow-sm{% if wrapper_class != blank %} {{ wrapper_class }}{% endif %}"
  >
    {{ video_media | video_tag: image_size: '1600x', autoplay: false, loop: should_loop, muted: true, controls: false, class: 'h-full w-full bg-foreground object-cover' }}

    {% if thumbnail_image != blank %}
      <button
        type="button"
        data-c-video-thumbnail
        class="absolute inset-0 z-10 block h-full w-full cursor-pointer overflow-hidden bg-foreground text-left transition-opacity"
        aria-label="Play video"
      >
        {{ thumbnail_image | image_url: width: 1600 | image_tag: alt: thumbnail_label, loading: 'lazy', class: 'h-full w-full object-cover' }}
        <span class="absolute inset-0 bg-foreground/20"></span>
      </button>
    {% endif %}

    <button
      type="button"
      data-c-video-play
      class="absolute inset-0 z-20 flex items-center justify-center transition focus:outline-none"
      aria-label="Play video"
    >
      <span data-c-video-play-label class="flex h-14 w-14 items-center justify-center rounded-full bg-black/40 text-white shadow-sm backdrop-blur transition hover:bg-black/60">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 translate-x-0.5" data-c-video-play-icon>
          <polygon points="5 3 19 12 5 21 5 3"/>
        </svg>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden h-6 w-6" data-c-video-pause-icon>
          <rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>
        </svg>
      </span>
    </button>

    <button
      type="button"
      data-c-video-mute
      class="absolute bottom-3 right-3 z-20 flex h-9 w-9 items-center justify-center rounded-full bg-black/40 text-white shadow-sm backdrop-blur transition hover:bg-black/60 focus:outline-none"
      aria-label="Unmute video"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" data-c-video-unmuted-icon>
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
        <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
        <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
      </svg>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden h-4 w-4" data-c-video-muted-icon>
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
        <line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>
      </svg>
    </button>
  </div>
{% endif %}
