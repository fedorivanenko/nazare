{% liquid
  assign banner_image = section.settings.image
  assign banner_image_alt = section.settings.image_alt | default: ''
  assign banner_heading = section.settings.heading
  assign banner_text_color = section.settings.text_color | default: 'dark'
  assign cta_label = section.settings.cta_label
  assign cta_url = section.settings.cta_url
  assign cta_scheme = section.settings.cta_scheme | default: 'solid'

  assign text_color_class = 'text-foreground'
  if banner_text_color == 'light'
    assign text_color_class = 'text-white'
  endif
%}

<section class="relative overflow-hidden py-30">
  {% if banner_image != blank %}
    {{
      banner_image
      | image_url: width: 2400
      | image_tag:
        alt: banner_image_alt,
        loading: 'lazy',
        class: 'absolute inset-0 h-full w-full object-cover'
    }}
  {% endif %}

  <div class="relative z-10 flex flex-col items-center justify-center px-6 py-16 text-center {{ text_color_class }}">
    {% if banner_heading != blank %}
      <h2 class="px-[15%] text-[90px]/[72px] font-heading font-bold uppercase mb-8 lg:text-[120px]/[96px]">{{ banner_heading | escape }}</h2>
    {% endif %}

    {% if cta_label != blank and cta_url != blank %}
      <div class="mt-8">
        {% render 'c-button', label: cta_label, url: cta_url, scheme: cta_scheme %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Banner",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Take the quiz"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text color",
      "default": "dark",
      "options": [
        { "value": "dark", "label": "Dark" },
        { "value": "light", "label": "Light" }
      ]
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label"
    },
    {
      "type": "select",
      "id": "cta_scheme",
      "label": "Button style",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "outline", "label": "Outline" },
        { "value": "ghost", "label": "Ghost" }
      ]
    },
  ],
  "presets": [
    {
      "name": "Banner"
    }
  ]
}
{% endschema %}
