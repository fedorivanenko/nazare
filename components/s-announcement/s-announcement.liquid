{% render 'section-css', section_name: 's-announcement' %}

{% liquid
  assign announcement_text = section.settings.text
  assign link_url = section.settings.link_url
  assign link_label = section.settings.link_label
  assign has_link = false

  if link_url != blank and link_label != blank
    assign has_link = true
  endif
%}

<section class="bg-announcement text-announcement-foreground">
  <div class="mx-auto flex max-w-screen-xl flex-col items-center justify-center gap-2 px-4 py-3 text-center text-sm font-medium sm:flex-row sm:text-left">
    {% if announcement_text != blank %}
      <p>{{ announcement_text }}</p>
    {% endif %}

    {% if has_link %}
      <a href="{{ link_url }}" class="inline-flex items-center rounded-full border border-announcement-foreground/30 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-announcement-foreground transition hover:border-announcement-foreground hover:bg-announcement-foreground hover:text-announcement focus:outline-none focus:ring-2 focus:ring-announcement-foreground focus:ring-offset-2 focus:ring-offset-announcement">
        {{ link_label }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Announcement",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "Free shipping on orders over $75."
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label"
    }
  ],
  "presets": [
    {
      "name": "Announcement"
    }
  ]
}
{% endschema %}
