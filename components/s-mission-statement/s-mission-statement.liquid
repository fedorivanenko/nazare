{% liquid
  assign ms_image = section.settings.image
  assign ms_image_alt = section.settings.image_alt | default: ''
  assign ms_heading = section.settings.heading
  assign ms_body = section.settings.body
  assign ms_text_color = section.settings.text_color | default: 'dark'
  assign cta_label = section.settings.cta_label
  assign cta_url = section.settings.cta_url
  assign cta_scheme = section.settings.cta_scheme | default: 'outline'
  assign ms_quote = section.settings.quote_text
  assign ms_person_image = section.settings.person_image
  assign ms_person_image_alt = section.settings.person_image_alt | default: ''
  assign ms_person_name = section.settings.person_name
  assign ms_person_role = section.settings.person_role

  if ms_image_alt == blank and ms_image.alt != blank
    assign ms_image_alt = ms_image.alt
  endif

  assign text_color_class = 'text-foreground'
  if ms_text_color == 'light'
    assign text_color_class = 'text-white'
  endif

  assign ms_has_person = false
  if ms_person_name != blank or ms_person_image != blank
    assign ms_has_person = true
  endif
%}

<section class="relative overflow-hidden bg-background text-foreground">
  {% if ms_image != blank %}
    {{
      ms_image
      | image_url: width: 2400
      | image_tag:
        alt: ms_image_alt,
        loading: 'lazy',
        class: 'absolute inset-0 h-full w-full object-cover'
    }}
  {% endif %}

  <div class="relative z-10">
    <div class="page-width grid grid-cols-1 gap-10 py-16 lg:grid-cols-2 lg:py-24">

      <div class="flex flex-col justify-center gap-6 {{ text_color_class }}">
        {% if ms_heading != blank %}
          <h2 class="text-3xl font-bold leading-tight lg:text-5xl">{{ ms_heading | escape }}</h2>
        {% endif %}

        {% if ms_body != blank %}
          <div class="text-base leading-7 opacity-80 [&_a:hover]:underline [&_a]:underline-offset-2">{{ ms_body }}</div>
        {% endif %}

        {% if cta_label != blank and cta_url != blank %}
          {% render 'c-button', label: cta_label, url: cta_url, scheme: cta_scheme %}
        {% endif %}
      </div>

      {% if ms_quote != blank %}
        <div class="flex items-center">
          <div class="rounded-2xl bg-white p-8 text-foreground shadow-xl">
            <p class="text-base leading-relaxed italic">&ldquo;{{ ms_quote | escape }}&rdquo;</p>

            {% if ms_has_person %}
              <div class="mt-6">
                {% render 'c-person',
                  image: ms_person_image,
                  image_alt: ms_person_image_alt,
                  name: ms_person_name,
                  role: ms_person_role
                %}
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mission statement",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our mission"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text color",
      "default": "dark",
      "options": [
        { "value": "dark", "label": "Dark" },
        { "value": "light", "label": "Light" }
      ]
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label"
    },
    {
      "type": "select",
      "id": "cta_scheme",
      "label": "Button style",
      "default": "outline",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "outline", "label": "Outline" },
        { "value": "ghost", "label": "Ghost" }
      ]
    },
    {
      "type": "header",
      "content": "Quote card"
    },
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Quote text"
    },
    {
      "type": "image_picker",
      "id": "person_image",
      "label": "Person photo"
    },
    {
      "type": "text",
      "id": "person_image_alt",
      "label": "Person photo alt text"
    },
    {
      "type": "text",
      "id": "person_name",
      "label": "Person name"
    },
    {
      "type": "text",
      "id": "person_role",
      "label": "Person role or title"
    }
  ],
  "presets": [
    {
      "name": "Mission statement"
    }
  ]
}
{% endschema %}
