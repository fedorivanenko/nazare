{% if section.blocks.size > 0 %}
  <section class="bg-background text-foreground">
    <div class="page-width py-6">
      <ul class="flex flex-wrap items-center justify-evenly gap-x-8 gap-y-4">
        {% for block in section.blocks %}
          {% if block.settings.label != blank %}
            <li class="flex items-center gap-2 text-sm font-medium" {{ block.shopify_attributes }}>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
              {{ block.settings.label }}
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Trust bar",
  "blocks": [
    {
      "type": "item",
      "name": "Trust item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Free shipping over $75"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust bar",
      "blocks": [
        { "type": "item", "settings": { "label": "Free shipping over $75" } },
        { "type": "item", "settings": { "label": "30-day money back guarantee" } },
        { "type": "item", "settings": { "label": "Clinically tested" } },
        { "type": "item", "settings": { "label": "24/7 customer support" } }
      ]
    }
  ]
}
{% endschema %}
