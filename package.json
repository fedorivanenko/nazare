{
	"name": "nazare-monorepo",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.0.0",
	"scripts": {
		"typecheck": "tsc -b",
		"test:compiler": "tsc -b && node --test packages/compiler/tests/*.test.mjs",
		"test:all": "tsc -b && node --test packages/compiler/tests/*.test.mjs packages/theme/tests/*.test.mjs packages/registry/tests/*.test.mjs packages/cli-client/tests/*.test.mjs apps/registry-api/tests/*.test.mjs",
		"test:registry": "tsc -b && node --test packages/registry/tests/*.test.mjs packages/cli-client/tests/install.test.mjs packages/cli-client/tests/publish.test.mjs",
		"test:server": "tsc -b && node --test apps/registry-api/tests/*.test.mjs",
		"test:types": "tsc -b && node --test packages/compiler/tests/type-expression.test.mjs",
		"test:diagnostics": "tsc -b && node --test packages/compiler/tests/diagnostics.test.mjs",
		"test:emit": "tsc -b && node --test packages/compiler/tests/emit.test.mjs packages/compiler/tests/root-marker.test.mjs packages/compiler/tests/references.test.mjs packages/compiler/tests/css-modules.test.mjs",
		"test:scripts": "tsc -b && node --test packages/compiler/tests/check-script.test.mjs packages/compiler/tests/runtime.test.mjs",
		"test:api": "tsc -b && node --test packages/compiler/tests/api.test.mjs",
		"test:cli": "tsc -b && node --test packages/theme/tests/*.test.mjs packages/cli-client/tests/*.test.mjs",
		"format": "biome format --write .",
		"lint": "biome check ."
	},
	"devDependencies": {
		"@types/node": "^26.1.1",
		"typescript": "^5.5.0"
	}
}
