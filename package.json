{
	"name": "nazare-monorepo",
	"private": true,
	"license": "MIT",
	"type": "module",
	"packageManager": "pnpm@10.0.0",
	"scripts": {
		"typecheck": "tsc -b",
		"check:fact-cache-revision": "node scripts/generate-fact-cache-revision.mjs --check",
		"dev:website": "pnpm --filter @nazare/website dev",
		"check:no-dist": "test -z \"$(git ls-files '*/dist/*')\"",
		"test:compiler": "pnpm -s build && node --test --test-concurrency=32 packages/compiler/tests/*.test.mjs",
		"test:corpus": "pnpm -s build && node scripts/check-theme-graph-corpus.mjs",
		"test:doc-agreement": "pnpm -s build && node scripts/check-doc-contract-agreement.mjs",
		"test:all": "pnpm -s build && NAZARE_FULL_CLI_TESTS=1 node --test --test-concurrency=32 packages/compiler/tests/*.test.mjs packages/theme/tests/*.test.mjs packages/registry/tests/*.test.mjs packages/cli-client/tests/*.test.mjs apps/registry-api/tests/*.test.mjs scripts/*.test.mjs",
		"test:theme": "pnpm -s build && node --test --test-concurrency=32 packages/theme/tests/*.test.mjs",
		"test:registry": "pnpm -s build && node --test --test-concurrency=32 packages/registry/tests/*.test.mjs packages/cli-client/tests/install.test.mjs packages/cli-client/tests/publish.test.mjs",
		"test:server": "pnpm -s build && node --test apps/registry-api/tests/*.test.mjs",
		"test:types": "pnpm -s build && node --test packages/compiler/tests/type-expression.test.mjs",
		"test:diagnostics": "pnpm -s build && node --test packages/compiler/tests/diagnostics.test.mjs",
		"test:emit": "pnpm -s build && node --test --test-concurrency=32 packages/compiler/tests/emit.test.mjs packages/compiler/tests/root-marker.test.mjs packages/compiler/tests/references.test.mjs packages/compiler/tests/css-modules.test.mjs",
		"test:scripts": "pnpm -s build && node --test --test-concurrency=32 packages/compiler/tests/check-script.test.mjs packages/compiler/tests/runtime.test.mjs",
		"test:api": "pnpm -s build && node --test packages/compiler/tests/api.test.mjs",
		"test:cli": "pnpm -s build && NAZARE_FULL_CLI_TESTS=1 node --test --test-concurrency=32 packages/cli-client/tests/*.test.mjs",
		"test:cli:smoke": "pnpm -s build && node --test --test-concurrency=32 packages/cli-client/tests/cli.test.mjs",
		"format": "biome format --write .",
		"lint": "biome check .",
		"build": "node scripts/generate-fact-cache-revision.mjs && tsc -b"
	},
	"devDependencies": {
		"@types/node": "^26.1.1",
		"typescript": "^5.5.0"
	}
}
