{
	"name": "nazare-monorepo",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.0.0",
	"scripts": {
		"typecheck": "tsc -b --force",
		"check:no-dist": "test -z \"$(git ls-files '*/dist/*')\"",
		"test:compiler": "pnpm -s build && node --test packages/compiler/tests/*.test.mjs",
		"test:all": "pnpm -s build && node --test packages/compiler/tests/*.test.mjs packages/theme/tests/*.test.mjs packages/registry/tests/*.test.mjs packages/cli-client/tests/*.test.mjs apps/registry-api/tests/*.test.mjs",
		"test:registry": "pnpm -s build && node --test packages/registry/tests/*.test.mjs packages/cli-client/tests/install.test.mjs packages/cli-client/tests/publish.test.mjs",
		"test:server": "pnpm -s build && node --test apps/registry-api/tests/*.test.mjs",
		"test:types": "pnpm -s build && node --test packages/compiler/tests/type-expression.test.mjs",
		"test:diagnostics": "pnpm -s build && node --test packages/compiler/tests/diagnostics.test.mjs",
		"test:emit": "pnpm -s build && node --test packages/compiler/tests/emit.test.mjs packages/compiler/tests/root-marker.test.mjs packages/compiler/tests/references.test.mjs packages/compiler/tests/css-modules.test.mjs",
		"test:scripts": "pnpm -s build && node --test packages/compiler/tests/check-script.test.mjs packages/compiler/tests/runtime.test.mjs",
		"test:api": "pnpm -s build && node --test packages/compiler/tests/api.test.mjs",
		"test:cli": "pnpm -s build && node --test packages/theme/tests/*.test.mjs packages/cli-client/tests/*.test.mjs",
		"format": "biome format --write .",
		"lint": "biome check .",
		"build": "tsc -b --force"
	},
	"devDependencies": {
		"@types/node": "^26.1.1",
		"typescript": "^5.5.0"
	}
}
