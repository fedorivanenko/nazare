{%- comment -%}
Generated by Nazare from registry/components/counter/counter.nz.liquid — do not edit.
{%- endcomment -%}
<div data-nz-ref="root" class="nazare-counter" data-start="{{ section.settings.start }}" data-prefix="{{ section.settings.prefix }}" data-nz-component="counter">
  <button data-nz-ref="decrement" type="button" data-step="{{ section.settings.step }}">&minus;</button>
  <output data-nz-ref="value">{{ section.settings.start }}</output>
  <button data-nz-ref="increment" type="button" data-step="{{ section.settings.step }}">+</button>
</div>
{{ 'counter.css' | asset_url | stylesheet_tag }}
{{ 'nazare-runtime.js' | asset_url | script_tag }}
{{ 'counter.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "counter",
  "settings": [
    {
      "type": "number",
      "id": "start",
      "label": "Start value",
      "default": 0
    },
    {
      "type": "range",
      "id": "step",
      "label": "Step",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 1
    },
    {
      "type": "text",
      "id": "prefix",
      "label": "Prefix",
      "default": ""
    }
  ]
}
{% endschema %}

=== assets/counter.css ===

.nazare-counter {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
}
.nazare-counter output {
  min-width: 3ch;
  text-align: center;
  font-variant-numeric: tabular-nums;
}
.nazare-counter button {
  inline-size: 2rem;
  block-size: 2rem;
}


