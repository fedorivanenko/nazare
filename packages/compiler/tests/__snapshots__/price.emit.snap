<span class="nz-price__styles__price" data-price data-nz-component="price">
  <span class="nz-price__styles__price__current">{{ price | money }}</span>

  {% if show_compare_at and compare_at_price and compare_at_price > price %}
    <s class="nz-price__styles__price__compare">{{ compare_at_price | money }}</s>
  {% endif %}
</span>
