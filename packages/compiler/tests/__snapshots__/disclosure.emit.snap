{% schema %}
{
  "name": "disclosure",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Trigger label",
      "default": "Details"
    }
  ]
}
{% endschema %}

=== assets/disclosure.css ===

.nazare-disclosure {
  display: block;
}
.nazare-disclosure--open > [data-nz-ref="panel"] {
  display: block;
}


