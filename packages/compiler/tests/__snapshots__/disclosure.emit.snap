<div data-nz-ref="root" class="nazare-disclosure" data-nz-component="disclosure">
  <button data-nz-ref="trigger" type="button">{{ section.settings.label }}</button>
  <div data-nz-ref="panel" hidden>
    <slot></slot>
  </div>
</div>
