<div class="nazare-notice nazare-notice--{{ block.settings.tone }}" {{ block.shopify_attributes }}>
  {{ block.settings.message }}
</div>
{{ 'notice.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "notice",
  "settings": [
    {
      "type": "text",
      "id": "message",
      "label": "Message",
      "default": "Heads up!"
    },
    {
      "type": "select",
      "id": "tone",
      "label": "Tone",
      "options": [
        {
          "value": "info",
          "label": "info"
        },
        {
          "value": "success",
          "label": "success"
        },
        {
          "value": "warning",
          "label": "warning"
        }
      ],
      "default": "info"
    }
  ],
  "presets": [
    {
      "name": "Notice"
    }
  ]
}
{% endschema %}

=== assets/notice.css ===

.nazare-notice {
  padding: 0.75rem 1rem;
  border-radius: 0.5rem;
}
.nazare-notice--info { background: rgb(219 234 254); }
.nazare-notice--success { background: rgb(220 252 231); }
.nazare-notice--warning { background: rgb(254 249 195); }


