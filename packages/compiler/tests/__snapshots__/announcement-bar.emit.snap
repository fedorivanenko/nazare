=== sections/announcement-bar.liquid ===
{%- comment -%}
Generated by Nazare from registry/components/announcement-bar/announcement-bar.nz.liquid — do not edit.
Hoisted settings (declared by dependencies):
  link_new_tab <- prop "new_tab" of registry/components/link/link.nz.liquid (via Link)
{%- endcomment -%}
<section class="nazare-announcement-bar">
  {% if section.settings.link != blank %}
    {% render 'link', href: section.settings.link, text: section.settings.text, class: "nazare-announcement-bar__link", new_tab: section.settings.link_new_tab %}
  {% else %}
    <span class="nazare-announcement-bar__text">
      {{ section.settings.text }}
    </span>
  {% endif %}
</section>

{% schema %}
{
  "name": "announcement-bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Free shipping on orders over $50"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Link"
    },
    {
      "type": "checkbox",
      "id": "link_new_tab",
      "label": "Open in new tab",
      "default": false,
      "info": "From registry/components/link/link.nz.liquid"
    }
  ]
}
{% endschema %}

