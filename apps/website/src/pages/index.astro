---
import "../styles/global.css";

// biome-ignore lint/correctness/noUnusedImports: Astro template renders this component.
import Button from "../components/Button.astro";
// biome-ignore lint/correctness/noUnusedImports: Astro template renders this component.
import CodeBlock from "../components/CodeBlock.astro";
// biome-ignore lint/correctness/noUnusedImports: Astro template renders this component.
import Footer from "../components/Footer.astro";

// biome-ignore lint/correctness/noUnusedVariables: Astro template passes this example into CodeBlock.
const installCommand = [
	"curl -fsSLO https://nazare.engineering/install",
	"less install",
	"sh install",
].join("\n");

// biome-ignore lint/correctness/noUnusedVariables: Astro template passes this example into CodeBlock.
const typesExample = [
	'{% import ProductCard from "./product-card.nz.liquid" %}',
	"{% props {",
	"  product: ShopifyProduct.required(),",
	"  showVendor: boolean.default(false),",
	"} %}",
	"",
	"{% render ProductCard {",
	"  product: props.product,",
	"  showVendor: props.showVendor,",
	"} %}",
].join("\n");

// biome-ignore lint/correctness/noUnusedVariables: Astro template passes this example into CodeBlock.
const diagnosticsExample = [
	"✓ product matches Product",
	"✓ showVendor expects boolean",
	"✓ all required props provided",
].join("\n");

// biome-ignore lint/correctness/noUnusedVariables: Astro template passes this example into CodeBlock.
const workspaceExample = [
	"themes/",
	"  main-store",
	"  outlet-store",
	"  campaign-store",
	"",
	"packages/",
	"  components",
	"  styles",
	"  utilities",
].join("\n");

// biome-ignore lint/correctness/noUnusedVariables: Astro template passes this example into CodeBlock.
const stackExample = `Nazare
│
├── Build
│   ├── Types / built
│   │   ├── .nz.liquid
│   │   ├── Typed props
│   │   ├── Explicit imports
│   │   ├── Composition
│   │   └── Liquid output
│   │
│   ├── Workspace / planned
│   │   ├── Multiple themes in one repository
│   │   ├── Shared packages
│   │   └── Theme-specific outputs
│   │
│   ├── Assets / planned
│   │   ├── CSS processing
│   │   ├── JavaScript processing
│   │   └── Asset transformations
│   │
│   ├── Extensions / built
│   │   └── Custom .mjs secondary outputs
│   │
│   ├── Plugin API / planned
│   │   ├── CSS hooks
│   │   ├── JavaScript hooks
│   │   └── Asset hooks
│   │
│   ├── Editor Tooling / planned
│   │   ├── Diagnostics
│   │   ├── Autocomplete
│   │   └── Theme Check integration
│   │
│   ├── Dev / planned
│   │   ├── Watch workspace and shared packages
│   │   ├── Run build incrementally
│   │   ├── Surface diagnostics
│   │   └── Integrate with Shopify CLI preview
│   │
│   └── Validate / planned
│       ├── Check templates
│       ├── Check component usage
│       └── Validate against storefront data
│
├── Registry
│   ├── Components / built
│   │   ├── Liquid
│   │   ├── .nz.liquid
│   │   ├── CSS
│   │   ├── JavaScript
│   │   └── Assets
│   │
│   ├── Private Registries / built
│   │   ├── Internal design systems
│   │   ├── Agency component libraries
│   │   └── Store-specific components
│   │
│   └── Browser / planned
│       ├── Browse components
│       ├── Preview states
│       ├── Test with mocked Shopify data
│       └── Read installation documentation
│
├── Runtime / partial
│   ├── Basic island runtime / built
│   ├── Runtime asset emission / built
│   ├── Load strategies / planned
│   ├── Rehydration + Shopify section events / planned
│   └── Framework adapters / planned
│
└── Inspect / partial
    ├── AST, IR, schema, artifact, and graph output / built
    ├── Theme structure / planned
    ├── Dependency graph / planned
    ├── Component and schema inventory / planned
    ├── Duplication and dead-code analysis / planned
    │
    ├── Migrate / planned
    │   ├── Consume Inspect output
    │   ├── Create a Nazare workspace
    │   └── Introduce Build and Types incrementally
    │
    ├── Intent / planned
    │   ├── Theme dependency graph
    │   ├── Storefront data model
    │   └── Explicit context for AI agents
    │
    └── Bridge / planned
        ├── Connect your own backend
        ├── A/B tests and feature rollouts
        └── Personalization and remote configuration`;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<script is:inline>
			(() => {
				try {
					const theme = localStorage.getItem("theme");
					if (theme === "dark" || theme === "light") {
						document.documentElement.dataset.theme = theme;
					}
				} catch {}
			})();
		</script>
		<title>Nazare</title>
		<meta
			name="description"
			content="Nazare is a family of open-source tools for building native Shopify themes that are easier to build, share, maintain, and evolve."
		/>
	</head>
	<body>
		<header class="site-header">
			<a href="/" aria-label="Nazare home"
			    style="display: block; text-decoration: none; font-size:20px; font-weight: 600;"
			>
			    Nazare
			</a>
			<nav aria-label="Primary navigation">
				<a href="/language">Language</a>
				<a href="https://github.com/fedorivanenko/nazare">GitHub</a>
			</nav>
		</header>
		<main class="site-shell stack">
			<section class="stack">
				<h1 class="heading--title"
				    style="max-width:20ch"
				>
					Reduce the cost of changing Shopify themes
				</h1>
				<p>
				    Nazare is an open-source toolkit that brings modern software engineering to native Shopify themes, making them easier to build, maintain, and evolve.
				</p>
				<p>
                    It introduces explicit interfaces, dependencies, and reusable abstractions, replacing implicit conventions with verifiable architecture that is easier for both humans and AI to understand, change, and automate.
				</p>
				<p>
				    Build with type-safe components, editable registries, and a structured project architecture—without leaving Shopify's native theme ecosystem.
				</p>
				<p>
				    Nazare does not require a rewrite.<br/>
					Start by intalling Nazare CLI and adopt incrementally.
				</p>
				<div class="code-block-group">
					<div class="code-block-group__header">
						<h3 class="heading--small">Install Nazare CLI</h3>
						<a
							class="muted"
							style="font-size:0.85rem;"
							href="https://raw.githubusercontent.com/fedorivanenko/nazare/main/scripts/install.sh"
						>
							View install script
						</a>
					</div>
					<CodeBlock code={installCommand} language="bash" />
				</div>
			</section>

			<section class="stack">
				<h2 class="heading--subtitle">Improve the DX without leaving Liquid</h2>
				<p>
					Liquid was designed as a simple, safe templating language. But modern Shopify
					themes are no longer simple.
				</p>
				<p>
					As themes grow into large, long-lived systems, the relationships between
					components, data, scripts, and templates remain mostly implicit. Developers
					spend more time tracing dependencies, checking parameters, duplicating patterns,
					testing manually, and avoiding unintended breakage.
				</p>
				<p>The usual response is to leave Liquid behind and rebuild headless.</p>
				<p>Nazare takes a different approach:</p>
				<p>→ keep Shopify’s native theme architecture and bring the best development primitives to it.</p>
			</section>

			<section class="stack">
				<h2 class="heading--subtitle">Registry</h2>
				<p><strong>Editable components for Shopify Liquid</strong></p>
				<p>
					Install styleless components directly into your project. Own the source, adapt
					every line, and publish your own public or private registry.
				</p>
				<p>Develop and deploy your private registries to speed up development.</p>
				<CodeBlock code="Components Gallery" language="text" />
				<p>→ <a href="/registry">Browse Registry</a></p>
			</section>

			<section class="stack">
				<h2 class="heading--subtitle">Types</h2>
				<p><strong>Safer, more composable Liquid</strong></p>
				<p>
					Add typed component interfaces, explicit imports, composition, and clear
					diagnostics through <code>.nz.liquid</code>.
				</p>
				<p>Nazare compiles the additional syntax to standard Liquid before deployment.</p>
				<CodeBlock code={typesExample} language="nz.liquid" />
				<CodeBlock code={diagnosticsExample} language="text" />
				<p>
					Write with explicit interfaces and diagnostics during development and deploy
					standard Shopify Liquid.
				</p>
				<p>→ <a href="/docs">Explore Types</a></p>
			</section>

			<section class="stack">
				<h2 class="heading--subtitle">Workspace</h2>
				<p>Manage several Shopify themes and shared packages in one monorepo-style repository.</p>
				<p>
					Share components, styles, utilities, and storefront logic across themes while
					keeping theme-specific code isolated.
				</p>
				<p>Each theme builds into a self-contained Shopify theme ready to deploy.</p>
				<CodeBlock code={workspaceExample} language="text" />
				<p>→ <a href="/docs">Explore Workspace</a></p>
			</section>

			<section class="stack">
				<h2 class="heading--subtitle">More of the stack</h2>
				<p>
					Nazare is growing into a complete development environment for native Shopify
					storefronts.
				</p>
				<CodeBlock code={stackExample} language="text" />
			</section>

			<section class="stack">
				<h2 class="heading--subtitle">Adopt incrementally</h2>
				<p>Nazare does not require a rewrite.</p>
				<p>
					Use each tool independently, or combine them as one integrated development
					environment.
				</p>
				<p>
					Start with one registry component. Add types to selected parts of your theme.
					Move shared code into packages when it becomes useful.
				</p>
				<p>
					Existing Liquid remains valid, and the deployed output stays compatible with
					Shopify’s native theme system.
				</p>
			</section>

			<section class="stack">
				<h2 class="heading--subtitle">Bring modern frontend ideas to Liquid</h2>
				<p>
					Over the past decade, JavaScript gained better ways to organize, compose,
					validate, and understand frontend code: modules, typed interfaces, reusable
					components, build graphs, registries, and intelligent editor tooling.
				</p>
				<p>Nazare brings those ideas to Liquid.</p>
				<p>
					Not by turning Liquid into JavaScript or replacing Shopify’s native runtime, but
					by adapting the best patterns of modern frontend development to the way Shopify
					themes actually work.
				</p>
			</section>

			<section class="stack">
				<h2 class="heading--subtitle">Open source</h2>
				<p>Nazare produces code you can inspect, change, and own.</p>
				<p>
					Registry components become part of your project. The compiler outputs standard
					Liquid. Themes remain deployable through Shopify’s normal workflow.
				</p>
				<p>No proprietary storefront runtime. No forced replatforming.</p>
			</section>

			<section class="stack">
				<h2 class="heading--subtitle">Build native Shopify themes that stay easy to evolve</h2>
				<p>Start with the tool you need today. Adopt more of the stack when it becomes useful.</p>
				<div class="button-row">
					<Button href="/language">Read language spec</Button>
					<Button href="/docs" variant="secondary">Get started</Button>
					<Button href="https://github.com/fedorivanenko/nazare" variant="secondary">View on GitHub</Button>
				</div>
				<blockquote>
					<p>One engineer can do a lot more today than a year ago.</p>
					<cite>Jarred Sumner</cite>
				</blockquote>
			</section>
		</main>
		<Footer />
	</body>
</html>
