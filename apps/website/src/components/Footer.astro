<footer class="site-footer">
	<div class="site-footer__inner">
		<span>{new Date().getFullYear()} Nazare</span>
		<nav class="site-footer__links" aria-label="Footer navigation">
			<a href="mailto:fedor@nazare.engineering">Email</a>
			<a href="https://github.com/fedorivanenko/nazare">GitHub</a>
			<a href="https://github.com/fedorivanenko/nazare/blob/main/LICENSE">MIT</a>
			<button
				class="theme-toggle"
				type="button"
				onclick="setTheme(document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark')"
			>
				Theme
			</button>
		</nav>
	</div>
	<script is:inline>
		window.setTheme = (theme) => {
			document.documentElement.dataset.theme = theme;
			localStorage.setItem("theme", theme);
		};
	</script>
</footer>
